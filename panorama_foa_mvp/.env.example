# Local MMAudio backend used for server validation.
MMAUDIO_MODEL_VARIANT=large_44k_v2
MMAUDIO_MODEL_PATH=.cache/weights/mmaudio
MMAUDIO_DEVICE=cuda:0
MMAUDIO_STEPS=25
MMAUDIO_GUIDANCE_SCALE=7.5
MMAUDIO_FULL_PRECISION=false
MMAUDIO_INFERENCE_MODE=euler
MMAUDIO_SONOWORLD_ROOT=

# Optional paid API providers. Leave blank for server smoke tests.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=
ELEVENLABS_API_KEY=
ELEVENLABS_SOUND_MODEL=eleven_text_to_sound_v2
